generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PAUSED
}

enum GoalType {
  LOSE
  MAINTAIN
  GAIN
}

enum ThreadTransport {
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MealEventType {
  MEAL_LOG
  CORRECTION
  DELETE
}

enum LoggingState {
  PENDING
  CONFIRMED
  AUTO_LOGGED
  NEEDS_CLARIFICATION
}

enum FoodSource {
  USDA
  BRANDED
  MANUAL
  LLM_ESTIMATE
}

enum OnboardingStep {
  GOAL
  BODY_STATS
  ACTIVITY
  DIET
  COMPLETE
}

model User {
  id             String         @id @default(cuid())
  phoneE164      String         @unique
  timezone       String         @default("America/New_York")
  status         UserStatus     @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        Profile?
  goals          Goal[]
  threads        Thread[]
  mealEvents     MealEvent[]
  dailyRollups   DailyRollup[]
  coachMemory    CoachMemory?
  corrections    Correction[]
  onboarding     OnboardingSession?
  workoutEvents  WorkoutEvent[]
}

model Profile {
  userId               String   @id
  firstName            String?
  sex                  String?
  birthYear            Int?
  heightCm             Float?
  startWeightKg        Float?
  currentWeightKg      Float?
  activityLevel        String?
  exerciseDaysPerWeek  Int?
  dietaryPreferences   Json?
  allergies            Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  goalType        GoalType
  targetWeightKg  Float?
  weeklyPaceKg    Float?
  targetCalories  Int?
  targetProteinG  Int?
  targetCarbsG    Int?
  targetFatG      Int?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id               String           @id @default(cuid())
  userId           String
  transport        ThreadTransport
  externalThreadId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
}

model Message {
  id                String            @id @default(cuid())
  threadId          String
  direction         MessageDirection
  provider          String
  providerMessageId String?           @unique
  bodyText          String?
  mediaCount        Int               @default(0)
  receivedAt        DateTime          @default(now())
  rawPayload        Json?
  createdAt         DateTime          @default(now())
  thread            Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mediaAssets       MediaAsset[]
  sourceMealEvents  MealEvent[]       @relation("SourceMessage")
  clarificationFor  Clarification[]   @relation("ClarificationAnswer")
}

model MediaAsset {
  id               String   @id @default(cuid())
  messageId        String
  providerMediaUrl String
  mimeType         String?
  storageKey       String?
  width            Int?
  height           Int?
  createdAt        DateTime @default(now())
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MealEvent {
  id               String         @id @default(cuid())
  userId           String
  sourceMessageId  String?
  eventType        MealEventType
  mealTime         DateTime?
  loggingState     LoggingState   @default(PENDING)
  confidenceScore  Float?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMessage    Message?       @relation("SourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  mealItems        MealItem[]
  clarifications   Clarification[]
}

model MealItem {
  id                String      @id @default(cuid())
  mealEventId       String
  nameRaw           String
  nameCanonical     String?
  quantity          Float?
  unit              String?
  gramsEstimated    Float?
  foodSource        FoodSource  @default(LLM_ESTIMATE)
  foodSourceRef     String?
  calories          Float?
  proteinG          Float?
  carbsG            Float?
  fatG              Float?
  fiberG            Float?
  confidenceScore   Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  mealEvent         MealEvent   @relation(fields: [mealEventId], references: [id], onDelete: Cascade)
  corrections       Correction[]
}

model Clarification {
  id                String    @id @default(cuid())
  mealEventId       String
  question          String
  answerMessageId   String?   @unique
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  mealEvent         MealEvent @relation(fields: [mealEventId], references: [id], onDelete: Cascade)
  answerMessage     Message?  @relation("ClarificationAnswer", fields: [answerMessageId], references: [id], onDelete: SetNull)
}

model DailyRollup {
  id              String   @id @default(cuid())
  userId          String
  dayDate         DateTime
  calories        Float    @default(0)
  proteinG        Float    @default(0)
  carbsG          Float    @default(0)
  fatG            Float    @default(0)
  fiberG          Float    @default(0)
  mealsLogged     Int      @default(0)
  caloriesBurned  Float    @default(0)
  workoutsLogged  Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayDate])
}

model WorkoutEvent {
  id             String   @id @default(cuid())
  userId         String
  rawText        String
  workoutLabel   String
  exercises      Json?
  muscleGroups   Json?
  durationMin    Int?
  caloriesBurned Int?
  workoutDate    DateTime @default(now())
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachMemory {
  userId                String   @id
  summary               String?
  strictnessMode        String?
  preferredCheckinTime  String?
  lastWeekSummary       Json?
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Correction {
  id              String    @id @default(cuid())
  userId          String
  mealItemId      String?
  correctionType  String
  oldValue        Json?
  newValue        Json?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItem        MealItem? @relation(fields: [mealItemId], references: [id], onDelete: SetNull)
}

model OnboardingSession {
  userId       String         @id
  currentStep  OnboardingStep @default(GOAL)
  answers      Json?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}
