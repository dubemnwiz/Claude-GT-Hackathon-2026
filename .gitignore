# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies (any directory named node_modules)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.Python

# Local / dev databases
*.db
*.sqlite
*.sqlite3

# testing
coverage/
/coverage

# next.js
.next/
out/
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — keep optional templates
.env
.env.*
!.env.example

# vercel
.vercel
vercel.env

# typescript
*.tsbuildinfo
# next-env.d.ts is generated but should be committed for consistent TS resolution

/app/generated/prisma

# caches
.turbo
.cache/

# IDE (optional local settings)
.idea/
