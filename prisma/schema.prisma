// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For simple credentials auth
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  diaryEntries  DiaryEntry[]
  weightLogs    WeightLog[]
  progressPhotos ProgressPhoto[]
  noteBlocks    NoteBlock[]
  tasks         Task[]
  workoutLogs   WorkoutLog[]
  countdowns    Countdown[]
  mediaItems    MediaItem[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  date      DateTime
  content   String
  rating    String?  // GOOD, MID, BAD
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  date      DateTime
  weight    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  date      DateTime
  url       String
  caption   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model NoteBlock {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // text, link, idea
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  content     String
  notes       String?
  status      String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  day         String   @default("Monday") // Monday, Tuesday, etc.
  priority    String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  weekOf      String?  // YYYY-MM-DD of the Monday of the week this task belongs to
  gcalEventId String?  // Google Calendar event ID for two-way sync
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime
  workout   String
  isPR      Boolean  @default(false)
  exercises Json?    // Array<{name:string, sets:[{weight:number, reps:number, isPR:boolean}]}>
  duration  Int?     // Minutes (cardio workouts)
  notes     String?  // Free-text notes (cardio pace, distance, etc.)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Countdown {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MediaItem {
  id         String   @id @default(cuid())
  title      String
  type       String   // BOOK, MOVIE, TV_SHOW
  status     String   @default("WANT_TO") // WANT_TO, IN_PROGRESS, DONE
  rating     Int?     // 1-5
  notes      String?
  posterUrl  String?  // TMDB poster or Google Books thumbnail
  externalId String?  // TMDB ID or Google Books volume ID
  year       Int?     // Release / publication year
  author     String?  // Book author(s) or movie director
  rank       Float?   // Fractional rank within DONE items (lower = better)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

